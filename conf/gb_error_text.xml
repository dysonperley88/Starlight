	<!-- Server Error Messages -->
	<trans_unit id="server_error_en" type="dialog">
      <message size="">
        <target xml:lang="en-UK"><![CDATA[A server error has occurred. Please wait awhile and try again.]]></target>
      </message>
    </trans_unit>	
	
	<trans_unit id="server_error_fr" type="dialog">
      <message size="">
        <target xml:lang="fr-FR"><![CDATA[Une erreur s'est produite sur le serveur. Veuillez patienter et réessayer ultérieurement.]]></target>
      </message>
    </trans_unit>	
	
	<trans_unit id="server_error_es" type="dialog">
      <message size="">
        <target xml:lang="es-ES"><![CDATA[Se ha producido un error en el servidor. Vuelve a intentarlo más tarde.]]></target>
      </message>
    </trans_unit>	
	
	<trans_unit id="server_error_de" type="dialog">
      <message size="">
        <target xml:lang="de-DE"><![CDATA[Ein Fehler ist aufgetreten. Der Server steht vorübergehend nicht zur Verfügung. Bitte versuche es später noch einmal.]]></target>
      </message>
    </trans_unit>	
	
	<trans_unit id="server_error_it" type="dialog">
      <message size="">
        <target xml:lang="it-IT"><![CDATA[Si è verificato un errore del server. Riprova più tardi.]]></target>
      </message>
    </trans_unit>	
	
	<trans_unit id="server_error_nl" type="dialog">
      <message size="">
        <target xml:lang="nl-NL"><![CDATA[Er is een serverfout opgetreden. Probeer het later nog eens.]]></target>
      </message>
    </trans_unit>	
	
	<!-- Nand Error Messages -->	
	
	<trans_unit id="nand_error_en" type="dialog">
      <message size=""><!-- The file cannot be used because the data is corrupted. -->
        <target xml:lang="en-UK"><![CDATA[Your save data is corrupt.<br/><br/>New save data is being created.]]></target>
      </message>
    </trans_unit>	
	
	<trans_unit id="nand_error_fr" type="dialog">
      <message size="">
        <target xml:lang="fr-FR"><![CDATA[Les données de sauvegarde de la chaîne sont corrompues.<br/><br/>De nouvelles données de sauvegarde vont être créées.]]></target>
      </message>
    </trans_unit>	
	
	<trans_unit id="nand_error_es" type="dialog">
      <message size="">
        <target xml:lang="es-ES"><![CDATA[Los datos guardados están dañados.<br/><br/>Se están generando nuevos datos guardados.]]></target>
      </message>
    </trans_unit>	
	
	<trans_unit id="nand_error_de" type="dialog">
      <message size="">
        <target xml:lang="de-DE"><![CDATA[Deine Speicherdaten sind fehlerhaft.<br/><br/>Neue Speicherdaten werden erstellt.]]></target>
      </message>
    </trans_unit>	
	
	<trans_unit id="nand_error_it" type="dialog">
      <message size="">
        <target xml:lang="it-IT"><![CDATA[I dati di salvataggio sono danneggiati.<br/><br/>Verranno creati dei nuovi dati di salvataggio.]]></target>
      </message>
    </trans_unit>	
	
	<trans_unit id="nand_error_nl" type="dialog">
      <message size="">
        <target xml:lang="nl-NL"><![CDATA[Je opgeslagen gegevens zijn beschadigd.<br/><br/>Er worden nieuwe opgeslagen gegevens gecreëerd.]]></target>
      </message>
    </trans_unit>		
	
